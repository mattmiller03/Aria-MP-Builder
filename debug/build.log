# 1. JSON size — pipes have a 64KB default buffer; 24 native-substituted kinds could blow past that
sudo docker run --rm --entrypoint /usr/local/bin/python microsoftazureadapter-test:8.19.2 -c "import sys, json; sys.path.insert(0, 'app'); import adapter; d = adapter.get_adapter_definition(); j = d.to_json(); print('JSON size:', len(json.dumps(j)), 'bytes')"

# 2. What's the image's entrypoint/cmd? mp-build runs through this — knowing what it is tells us which layer to inspect next
sudo docker inspect microsoftazureadapter-test:8.19.2 | grep -A 5 -iE '"Entrypoint"|"Cmd"|"WorkingDir"'

# 1. Start the container in the background with its real entrypoint
sudo docker run -d --name azure-test -p 8181:8080 microsoftazureadapter-test:8.19.2
sleep 3

# 2. Confirm it's up
sudo docker ps | grep azure-test

# 3. Hit the endpoint and capture both response and container logs
echo "=== HTTP RESPONSE ==="
curl -s -w "\nHTTP %{http_code}\n" http://localhost:8080/adapterDefinition | head -100

echo ""
echo "=== CONTAINER LOGS ==="
sudo docker logs azure-test 2>&1 | tail -60

# 4. Also grab the adapter's own log file inside the container
echo ""
echo "=== adapter.log INSIDE CONTAINER ==="
sudo docker exec azure-test cat /home/aria-ops-adapter-user/src/adapter.log 2>&1 | tail -60

# 5. Cleanup
sudo docker rm -f azure-test


