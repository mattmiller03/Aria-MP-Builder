<?xml version="1.0" encoding="UTF-8"?>
<alertContent>
    <AlertDefinitions>
        <!-- VM CPU Utilization very high -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov VM CPU Utilization is very high"
            id="AlertDefinition-ag-vm-cpu-high"
            resourceKind="azure_virtual_machine" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="or">
                    <Symptom ref="SymptomDefinition-ag-vm-cpu-critical"/>
                    <Symptom ref="SymptomDefinition-ag-vm-cpu-immediate"/>
                    <Symptom ref="SymptomDefinition-ag-vm-cpu-warning"/>
                </SymptomSet>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>

        <!-- VM Powered Off -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov VM is powered off"
            id="AlertDefinition-ag-vm-powered-off"
            resourceKind="azure_virtual_machine" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="and"
                    ref="SymptomDefinition-ag-vm-power-state"/>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>

        <!-- SQL Database CPU Utilization very high -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov SQL Database CPU Utilization is very high"
            id="AlertDefinition-ag-sql-cpu-high"
            resourceKind="azure_sql_database" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="or">
                    <Symptom ref="SymptomDefinition-ag-sql-cpu-critical"/>
                    <Symptom ref="SymptomDefinition-ag-sql-cpu-immediate"/>
                    <Symptom ref="SymptomDefinition-ag-sql-cpu-warning"/>
                </SymptomSet>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>

        <!-- SQL Database DTU Utilization very high -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov SQL Database DTU Utilization is very high"
            id="AlertDefinition-ag-sql-dtu-high"
            resourceKind="azure_sql_database" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="or">
                    <Symptom ref="SymptomDefinition-ag-sql-dtu-critical"/>
                    <Symptom ref="SymptomDefinition-ag-sql-dtu-immediate"/>
                    <Symptom ref="SymptomDefinition-ag-sql-dtu-warning"/>
                </SymptomSet>
                <Impact key="health" type="badge"/>
                <Recommendations>
                    <Recommendation priority="1" ref="Recommendation-ag-upgrade-dtu"/>
                </Recommendations>
            </State>
        </AlertDefinition>

        <!-- Storage Account Availability low -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov Storage Account Availability is below 95%"
            id="AlertDefinition-ag-storage-availability"
            resourceKind="azure_storage_account" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="and"
                    ref="SymptomDefinition-ag-storage-availability"/>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>

        <!-- Load Balancer Data Path Availability low -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov Load Balancer Data Path Availability is low"
            id="AlertDefinition-ag-lb-availability"
            resourceKind="azure_load_balancer" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="and"
                    ref="SymptomDefinition-ag-lb-availability"/>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>

        <!-- App Service Not Running -->
        <AlertDefinition adapterKind="AzureGovAdapter"
            description="Azure Gov App Service is not running"
            id="AlertDefinition-ag-app-not-running"
            resourceKind="azure_app_service" subType="19" type="15">
            <State severity="automatic">
                <SymptomSet applyOn="self" operator="and"
                    ref="SymptomDefinition-ag-app-not-running"/>
                <Impact key="health" type="badge"/>
            </State>
        </AlertDefinition>
    </AlertDefinitions>

    <SymptomDefinitions>
        <!-- VM CPU symptoms: warning 85%, immediate 90%, critical 95% -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-vm-cpu-warning"
            resourceKind="azure_virtual_machine" waitCycle="3">
            <State severity="warning">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="85.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-vm-cpu-immediate"
            resourceKind="azure_virtual_machine" waitCycle="3">
            <State severity="immediate">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="90.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-vm-cpu-critical"
            resourceKind="azure_virtual_machine" waitCycle="3">
            <State severity="critical">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="95.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>

        <!-- VM Power State symptom -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="2"
            id="SymptomDefinition-ag-vm-power-state"
            resourceKind="azure_virtual_machine" waitCycle="2">
            <State severity="info">
                <Condition key="power_state" operator="!="
                    thresholdType="static" type="property"
                    value="running" valueType="string"/>
            </State>
        </SymptomDefinition>

        <!-- SQL Database CPU symptoms -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-cpu-warning"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="warning">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="85.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-cpu-immediate"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="immediate">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="90.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-cpu-critical"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="critical">
                <Condition key="CPU|cpu_usage" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="95.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>

        <!-- SQL Database DTU symptoms -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-dtu-warning"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="warning">
                <Condition key="Workload|dtu_consumption" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="85.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-dtu-immediate"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="immediate">
                <Condition key="Workload|dtu_consumption" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="90.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-sql-dtu-critical"
            resourceKind="azure_sql_database" waitCycle="3">
            <State severity="critical">
                <Condition key="Workload|dtu_consumption" operator="&gt;"
                    thresholdType="static" type="metric"
                    value="95.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>

        <!-- Storage Account Availability below 95% -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-storage-availability"
            resourceKind="azure_storage_account" waitCycle="3">
            <State severity="warning">
                <Condition key="Availability|availability" operator="&lt;"
                    thresholdType="static" type="metric"
                    value="95.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>

        <!-- Load Balancer Data Path Availability below 95% -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="3"
            id="SymptomDefinition-ag-lb-availability"
            resourceKind="azure_load_balancer" waitCycle="3">
            <State severity="warning">
                <Condition key="Availability|data_path_availability" operator="&lt;"
                    thresholdType="static" type="metric"
                    value="95.0" valueType="numeric"/>
            </State>
        </SymptomDefinition>

        <!-- App Service Not Running -->
        <SymptomDefinition adapterKind="AzureGovAdapter" cancelCycle="2"
            id="SymptomDefinition-ag-app-not-running"
            resourceKind="azure_app_service" waitCycle="2">
            <State severity="warning">
                <Condition key="state" operator="!="
                    thresholdType="static" type="property"
                    value="Running" valueType="string"/>
            </State>
        </SymptomDefinition>
    </SymptomDefinitions>

    <Recommendations>
        <Recommendation id="Recommendation-ag-upgrade-dtu"
            description="Consider upgrading the DTU tier or reducing database load to improve performance."/>
    </Recommendations>
</alertContent>
